# Copy this file to .env and fill in real values before running the pipeline.
# Never commit .env to git — it is listed in .gitignore.
#
# Usage (local dev):
#   cp .env.example .env
#   # Edit .env and replace every "changeme" with a real value.
#   source .env   # or use python-dotenv / direnv
#
# Usage (CI / remote host):
#   Set variables directly in the shell or CI secrets store — no file needed.

# ---------------------------------------------------------------------------
# Data provider credentials (required)
# ---------------------------------------------------------------------------
# API key for the market-data provider used during ingestion.
CRYPTAN_DATA_API_KEY=changeme

# API secret for the market-data provider.
CRYPTAN_DATA_API_SECRET=changeme

# ---------------------------------------------------------------------------
# Optional overrides
# ---------------------------------------------------------------------------
# Override the artifacts output directory (default: artifacts/).
# CRYPTAN_ARTIFACTS_DIR=artifacts
